# LLM settings
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=gpt-4o-mini

# law.go.kr OpenAPI credential suffix
LAW_OC=dhl

# Local embedding model
EMBEDDING_MODEL=nlpai-lab/KoE5

# Local reranker model
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Qdrant vector database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
COLLECTION_NAME=foundation_docs

# App metadata
APP_TITLE=경기테크노파크 규정 및 관계법령 가이드북

# Chunking and retrieval settings
CHUNK_SIZE=800
CHUNK_OVERLAP=200
TOP_K=5
RERANK_CANDIDATES=12

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=8088
INTERNAL_BACKEND_PORT=28000
INTERNAL_FRONTEND_PORT=28088
INTERNAL_QDRANT_PORT=26333
INTERNAL_QDRANT_GRPC_PORT=26334

# Frontend deployment subpath
VITE_PUBLIC_BASE_PATH=/chat/

# Leave blank to derive /chat/api automatically
VITE_API_URL=

